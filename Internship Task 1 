        "!pip install seaborn\n",
        "\n",
        "import pandas as pd\n",
        "import seaborn as sns\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# Load the dataset\n",
        "# The Iris dataset is available directly in seaborn, so we'll load it from there\n",
        "iris = sns.load_dataset(\"iris\")\n",
        "\n",
        "# Print the shape, column names, and first few rows\n",
        "print(\"Shape of the dataset:\", iris.shape)\n",
        "print(\"\\nColumn names:\", iris.columns)\n",
        "print(\"\\nFirst 5 rows:\\n\", iris.head())\n",
        "\n",
        "# Use .info() and .describe() for summary statistics\n",
        "print(\"\\nDataset Info:\\n\")\n",
        "iris.info()\n",
        "print(\"\\nDataset Description:\\n\", iris.describe())\n",
        "\n",
        "# Visualize the dataset\n",
        "\n",
        "# Scatter plot to show relationships between features\n",
        "# Using a Pairplot to visualize relationships between all pairs of features\n",
        "print(\"\\nGenerating Pairplot...\")\n",
        "sns.pairplot(iris, hue=\"species\")\n",
        "plt.suptitle(\"Pairplot of Iris Dataset by Species\", y=1.02)\n",
        "plt.show()\n",
        "\n",
        "# Histograms to show value distributions\n",
        "print(\"\\nGenerating Histograms...\")\n",
        "iris.hist(edgecolor='black', linewidth=1.2)\n",
        "plt.suptitle(\"Histograms of Iris Features\", y=1.02)\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "# Box plots to identify outliers\n",
        "print(\"\\nGenerating Box Plots...\")\n",
        "plt.figure(figsize=(10, 6))\n",
        "sns.boxplot(data=iris.drop('species', axis=1))\n",
        "plt.title(\"Box Plots of Iris Features\")\n",
        "plt.ylabel(\"Measurement (cm)\")\n",
        "plt.show()\n",
        "\n",
        "# Box plots for each feature separated by species\n",
        "print(\"\\nGenerating Box Plots by Species...\")\n",
        "plt.figure(figsize=(12, 8))\n",
        "for i, col in enumerate(iris.columns[:-1]):\n",
        "    plt.subplot(2, 2, i + 1)\n",
        "    sns.boxplot(x='species', y=col, data=iris)\n",
        "    plt.title(f'Box Plot of {col} by Species')\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ]
